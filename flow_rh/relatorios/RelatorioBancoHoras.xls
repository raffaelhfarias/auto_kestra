     @import url('https://fonts.googleapis.com/css2?family=Lexend:wght@200;300;400;500;600;700;800;900&display=swap');
     @import url('https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600;700;800;900&display=swap');

     .onboarding-tangerino .shepherd-content,
     .onboarding-tangerino .shepherd-text,
     .onboarding-tangerino .shepherd-title,
     .onboarding-tangerino .shepherd-button,
     .onboarding-tangerino .shepherd-element {
       font-family: 'Lexend', sans-serif !important;
     }

     .onboarding-tangerino .shepherd-content {
       background-color: #FFFFFF;
       border-radius: 16px;
     }

     .onboarding-tangerino .shepherd-text {
       color: #000000;
       font-size: 14px;
       line-height: 24px;
       font-weight: 400;
       padding: 0.75em 24px;
     }

     .onboarding-tangerino.shepherd-has-title .shepherd-content .shepherd-header {
       background: #fff;
       height: auto;
       padding: 1rem 1.5rem;
     }

     .onboarding-tangerino .shepherd-title {
       color: #272727;
       font-weight: 700 !important;
       font-size: 22px !important;
       line-height: 32px !important;
     }

     .onboarding-tangerino .shepherd-header {
       align-items: center;
       border-top-left-radius: 16px;
       border-top-right-radius: 16px;
       border-bottom: 1px solid #F1F1F1;
       margin-left: 0;
       box-shadow: none !important
     }

     .onboarding-tangerino .shepherd-footer {
       border-top: 1px solid #F1F1F1;
       border-bottom-left-radius: 16px;
       border-bottom-right-radius: 16px;
       padding: 1rem 1.5rem !important;
       height: auto;
       margin-left: 0 !important;
       width: 100% !important;
       position: relative;
     }

     .onboarding-tangerino.shepherd-element {
       border-radius: 16px;
       max-width: 500px;
     }

     i {
       margin-left: 4px !important;
     }

     .onboarding-tangerino .shepherd-footer button.shepherd-button {
       padding: 1rem 1.5rem;
       font-weight: 600;
       box-shadow: none;
       border-radius: 8px;
       cursor: pointer;
       background: #821B71;
       border: 0;
       color: white;
     }

