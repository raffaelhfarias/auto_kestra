    $(document).ready(function () {
      $(".campoData").mask('00/00/0000');
      $(".campoCpf").mask('000.000.000-00');
      $(".campoCnpj").mask('00.000.000/0000-00');
      $(".campoCep").mask('00000-000');
      $('.campoCelular').mask('(00) 00000-0000');
      var behavior = function (val) {
          return val.replace(/\D/g, '').length === 11 ? '(00) 00000-0000' : '(00) 0000-00009';
        },
        options = {
          onKeyPress: function (val, e, field, options) {
            field.mask(behavior.apply({}, arguments), options);
          }
        };
      $('.campoTelefone').mask(behavior, options);
    });

    $(document).ready(function () {
      $('.js-basic-select-field').select2({
        theme: "bootstrap"
      });

      $('.press-enter-to-search').keypress(function (event) {
        if (event.which === 13) {
          $('.search-button').click();
        }
      });

    });

    function limitText(limitField, limitNum) {
      if (limitField.value.length > limitNum) {
        limitField.value = limitField.value.substring(0, limitNum);
      }
    }

    function initializeImageComponent() {
      $("a[rel='contentPicture']").fancybox({
        buttons: [
          'zoom',
          'thumbs',
          'close'
        ],
        thumbs: {
          autoStart: true
        }
      });
    }
  </script>

