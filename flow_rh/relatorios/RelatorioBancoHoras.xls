<div id="geral">

  <!-- Chat do ZenDesk -->

  

  <!-- Chat do ZenDesk fim -->

  <section class="s-section">


  <script>
    $(document).ready(function () {
      toggleClassAtivoLink();
      leaveMenuPerfil();
      enterMenuPerfil();
      isPromotionalStripe();
  });

    function toggleChevron(a) {
      var menuLateral = document.querySelector('.menu-lateral');
      if (a.classList.contains('ativo')) {
        a.classList.remove('ativo');
        menuLateral.classList.remove('hover-dinamico')
      } else {
        a.classList.add('ativo');
        menuLateral.classList.add('hover-dinamico');
      }

      document.body.classList.toggle('contraido');
      addAtivo();
      removeAtivo();

      return false
    }

    function removeAtivo() {
      var elem = document.querySelectorAll('.item-menu.pricing-ativo');
      var isContraido = document.body.classList.contains('contraido');

      if (isContraido && elem !== undefined && elem !== null) {
        elem.forEach(function (item, idx) {
          item.classList.remove('pricing-ativo');
        })
      }


    }

    function removeAtivoSubItems() {
      var elem = document.querySelectorAll('.active-option-menu');
      if (elem !== undefined && elem !== null) {
        elem.forEach(function (elm, idx) {
          elm.classList.remove('pricing-ativo');
        })
      }
    }


    function toggleClassAtivoLink() {
      var elem = document.querySelector('.item-menu.item-link');

      if(elem == null){
        return;
      }

      if (window.location.href.includes('HomePage') || window.location.href.includes('actionHome')) {
        elem.classList.add('ativo');
        return
      }

      var elems = document.querySelectorAll('.item-link');
      elems.forEach(function (e) {
        if (e.href.includes(window.location.href.split('baseContent')[1])) {
          e.classList.add('ativo');
          return;
        }
      });
    }

    function isTrial(){
      var isTrial = $('.hiddenIsTrial').val();
      return isTrial === 'true';
    }

    function leaveMenuPerfil() {
      document.querySelector('.option-header').addEventListener('mouseleave', function () {
        var elem = document.querySelector('.avatar.ativo');
        if (elem !== undefined && elem !== null) {
          elem.classList.remove('ativo');
        }
      })
    }

    function enterMenuPerfil() {
      document.querySelector('.avatar').addEventListener('mouseenter', function () {
        this.classList.add('ativo');
      })
    }

    function isPromotionalStripe() {
      var elm = document.querySelector('.promotionalStripe');
      if (elm !== undefined && elm !== null) {
        var coluna = document.getElementById('coluna2');
        if (coluna !== undefined && coluna !== null) {
          coluna.style.height = 'calc(100vh - 240px)';
        }
      }
    }

    function openOnboardingTrial(){
      // Disabled to prevent the old onboarding from being triggered
      // localStorage.removeItem('tourStep');
      // localStorage.removeItem('tutorial_trial');
      console.log("Old onboarding has been disabled in favor of the new onboarding system");
    }


   document.addEventListener("DOMContentLoaded", function () {
      document.addEventListener("click", function (event) {
          let link = event.target.closest("a");

          if (link && link.href) {
              if (event.ctrlKey || event.metaKey) {
                  event.preventDefault();
                  event.stopImmediatePropagation();
                  window.open(link.href, "_blank");
              }
          }
      }, true);
   });

  </script>
  <style>
    #corpo {
      margin-left: 0 !important;
    }

    footer {
      height: 50px;
      width: calc(100% - var(--aside) - 20px) !important;
      position: fixed;
      bottom: 0;
      padding: 0px 10px !important;
      margin-left: var(--aside) !important;
    }

    .icone-rodape {
      padding: 0px !important;
      margin: 0px !important;
      position: relative !important;
    }

    #coluna2 {
      margin: 0 !important;
      height: calc(100vh - 160px);
    }

    .ativo .fa-solid.direita,
    body:not(.contraido) .active-option-menu .alinha-direita {
      transform: rotate(90deg);
    }

    .timeOffWorkLink {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .pular{
      border: none !important;
      background: none !important;
      color: #821B71 !important;
      text-decoration: underline;
      position: sticky;
      right: 100%;
    }

    .shepherd-cancel-icon{
      min-width: 0px !important;
    }

    .no-click {
      pointer-events: none;
    }

    .title-tour{
      display:flex;
      align-items: flex-start;
      flex-direction: column;
      justify-content: start;
      margin-top:5px;
      width: 435px;
    }

    .btn-tour-voltar{
      background: #F4E4EE !important;
      border: 1px solid #F4E4EE !important;
      color: #48004A !important;
    }

  </style>

