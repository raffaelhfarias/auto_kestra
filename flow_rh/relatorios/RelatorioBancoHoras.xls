<style>

  body {
    font-family: "Myriad Pro", Verdana, Arial, Tahoma;
    padding-bottom: 0 !important;
  }

  #conteudo {
    height: 100% !important;
  }

  .dash-content {
    height: 100%;
  }

  #corpo {
    height: 100%;
    background: none;
    overflow-y: auto;
    clear: both;
    border-radius: 0px;
  }


  footer {
    background: #fff !important;
  }
</style>

<script>
  $(document).ready(function () {

    setTimeout(function () {
      var elem = document.getElementById('launcher');
      if (elem !== undefined && elem !== null) {
        elem.style.bottom = '40px';
      }
    }, 1500)

  });

  var checkOpenChatCookie = function () {
    var openChatValue = getCookieValueByName('openChat');

    if (openChatValue === 'true') {
      $('#launcher').contents().find('button').click();

      var seconds = new Date().getSeconds() + 18;
      var expireDate = new Date();
      expireDate.setSeconds(seconds);


      document.cookie = 'openChat=false; expires=' + expireDate.toUTCString();
    }
  };

  var gaClickEvent;

  function getCookieValueByName(name) {
    var cookies = document.cookie.split("; ");

    for (var i = 0; i < cookies.length; i++) {
      var cookie = cookies[i];
      var values = cookie.split("=");

      if (values[0] === name) {
        return values[1];
      }

    }
  }

  $(document).ready(function () {
    var employeeData = $('.hiddenEmployeeData').val();

    let element = document.querySelector(".base-page-titulo");
    if(element == null) {
      element = document.querySelector(".page-header h6 strong")
    }
    let title = element ? element.innerText : "";

    if (employeeData) {
      var valueData = JSON.parse(employeeData);

      var dataLayer = window.dataLayer;
      dataLayer.push({
        'event': 'virtualPageView',
        'userId': valueData.codeReference,
        'pageTitle': valueData.pageTitle + ' | ' + (title || sessionStorage.getItem("pageTitle")),
        'companyCode': valueData.organizationCodeReference,
        'userProfile': valueData.userProfile,
        'accountStatus': valueData.accountStatus,
      })


      gaClickEvent = function (elementName) {
        if(!elementName) {
          return;
        }
        let partes = elementName.split("_");
        if(partes.length >= 2 && (partes[1] === '' || /\d+/gm.test(partes[1]))) {
          return;
        }
        if(elementName.includes("_")) {
          dataLayer.push({
            'event': 'click',
            'userId': valueData.codeReference,
            'pageTitle': valueData.pageTitle + ' | ' + (title || sessionStorage.getItem("pageTitle")),
            'companyCode': valueData.organizationCodeReference,
            'userProfile': valueData.userProfile,
            'accountStatus': valueData.accountStatus,
            'elementName': elementName
          })
        }
      }

      window.addEventListener('message', function(event) {
        if (event.data && event.data.type === 'PUSH_DATALAYER_EVENT') {
          const ev = event.data.event;
          gaClickEvent(ev.elementName);
        }
      });

      function toPascalCase(value) {
        return value.normalize("NFD").replace(/[\u0300-\u036f]/g, "") // Remove acentos
          .split(/\s+/) // Divide por espaços
          .map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()) // Capitaliza
          .join("");
      }

      function getLabel(element) {
        const attributes = ['value', 'title', 'class', 'id']
        if (element.textContent.trim()) {
          return element.textContent.trim();
        } else {
          for (const attributeKey of attributes) {
            let label = element.getAttribute(attributeKey);
            if (label != null && label.trim()) {
              return label.trim();
            }
          }
          return '';
        }
      }

      function setTitleFechar() {
        setTimeout(() => {
          $('.w_close').attr("title", "Fechar")
        }, 500)
      }

      function closeModalOnClick() {
        setTimeout(function () {
          $('.w_close').attr("title", "Fechar")
          $('input[type=button]').on('click', (event) => {
            let label = getLabel(event.target);
            gaClickEvent('botao_' + toPascalCase(label));
          })
          $('.wicket-mask-dark').on('click', function () {
            $('.w_close').click()
          });
        }, 500);
      }

      $(document).on('click', 'button, input[type=button], input[type=submit]', function(event) {
        let label = getLabel(event.target);
        gaClickEvent('botao_' + toPascalCase(label));
      });
      $(document).on('click', '.aba li a', function(event) {
        let label = getLabel(event.target);
        gaClickEvent('aba_' + toPascalCase(label));
        event.stopPropagation();
      });

      $(document).on('click', 'a', function(event) {
        let label = getLabel(event.target);
        sessionStorage.setItem("pageTitle", label)
        gaClickEvent('link_' + toPascalCase(label));
      });

      $(document).on('click', '.option-menu-pricing-funcionalidade-anchor', function(event) {
        let label = event.target.querySelector("span:first-child").textContent;
        sessionStorage.setItem("pageTitle", label)
        gaClickEvent('link_' + toPascalCase(label));
      });


      $(document).on('click', '.fa-copy', function (event) {
        let label = getLabel(event.target);
        gaClickEvent('botao_' + toPascalCase(label ? label : 'duplicar'));
      })

      $(document).on('click', '.icone.excluir', function (event) {
        let label = getLabel(event.target);
        gaClickEvent('botao_' + toPascalCase(label ? label : 'excluir'));
      })

      $(document).on('click', 'input[type=file]', function(event) {
        gaClickEvent('botao_AnexoArquivo');
      });

      const iframe = document.querySelector('iframe');
      if (iframe) {
        iframe.addEventListener('load', function() {
          try {
            const iframeDoc = iframe.contentDocument || iframe.contentWindow.document;

            const botoesIframe = iframeDoc.querySelectorAll('button');

            const inputsIframe = iframeDoc.querySelectorAll('input[type=button], input[type=submit]');

            [...botoesIframe, ...inputsIframe].forEach(element =>
              element.addEventListener('click', (event) => gaClickEvent('botao_' + (element.getAttribute('name') || element.getAttribute('id') || '')))
            );

          } catch (error) {
            console.error("Erro ao acessar o iframe:", error);
          }
        });
      }
    }


  })





  setInterval(checkOpenChatCookie, 3000);
</script>

</body>
</html>




