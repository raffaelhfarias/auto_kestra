       background: white;
       border: 1px solid #821B71;
       color: #821B71;
     }

     .onboarding-tangerino .shepherd-arrow:before {
       box-shadow: 0 1px 4px rgba(0, 0, 0, .2);
     }

     .onboarding-tangerino.shepherd-element.shepherd-has-title[data-popper-placement^=bottom] > .shepherd-arrow:before {
       background-color: #fff;
     }

