  <script type="text/javascript">

    $(document).ready(function () {
      $('.js-basic-select-field-local').select2({
        theme: "bootstrap"
      });

      $('.dropdown-tipos-beneficios').select2({
        theme: "bootstrap"
      });

      $(".expande-fieldset").click(function () {
        $(this.parentNode.parentNode).toggleClass("contrai-fieldset");
      });

      $('.dropdown-status-employee').change(function () {
        reloadFuncionarios();
      });
      $('.dropdown-local-trabalho').change(function () {
        reloadFuncionarios();
      });
      $('.dropdown-empresa').change(function () {
        reloadFuncionarios();
        reloadLocaisTrabalho();
      });

      $('.dropdown-gestor').change(function () {
        reloadFuncionarios();
      });

      $('.dropdown-empresa').change(function () {
        reloadFuncionarios();
        reloadLocaisTrabalho();
      });
      $('.dropdown-zonaVenda').change(function () {
        reloadFuncionarios();
      });

      $('.dropdown-cargo').change(function () {
        reloadFuncionarios();
      });

      $('.dropdown-local-trabalho').change(function () {
        reloadFuncionarios();
      });

      $('.dropdown-regra-ponto').change(function () {
        reloadFuncionarios();
      });

      $('.containerNSR').hide();

      $('.dropdown-formato-afd').change(function () {
        if ($('.dropdown-formato-afd').val() !== '0') { // AFD Id
          $('.containerExportarPontosOriginais').hide();
          $('.containerExibirPorNSROuData').hide();
          $('.containerNSR').hide();
          $('.containerDateRange').show();
          $('.exportarPorNSROuData').prop('checked', false);
        } else {
          $('.containerExportarPontosOriginais').show();
          $('.containerDateRange').show();
          $('.containerNSR').hide();
          $('.containerExibirPorNSROuData').show()
        }
      });

      $('.dropdown-status-employee').change(function () {
        if ($('.dropdown-status-employee').val() === '0') { // Todos id
          reloadFuncionarios();
        }
        if ($('.dropdown-status-employee').val() === '1') { // Admitidos id
          reloadFuncionarios();
        }
        if ($('.dropdown-status-employee').val() === '2') { // Demitidos id
          reloadFuncionarios();
        }
      });

      $('.exportarPorNSROuData').change(function () {
        if ($('.exportarPorNSROuData').is(':checked')) {
          $('.containerDateRange').hide();
          $('.containerNSR').show();
        } else {
          $('.containerDateRange').show();
          $('.containerNSR').hide();
        }
      });

      $(".dropdown-tipoRelatorio").change(function () {
        if ($(".dropdown-tipoRelatorio").val() != '1') {
          $(".container-tolerancia").hide();
        } else {
          $(".container-tolerancia").show();
        }
      });

      $(".containerExibirGestorAbsenteismo").hide();

      $(".containerFormat").change(function () {
      if($(".containerFormat").val() !== '0'){
        $(".containerExibirGestorAbsenteismo").hide();
        }else{
        $(".containerExibirGestorAbsenteismo").show();
      }
      });

      reloadFuncionarios();
      reloadLocaisTrabalho();

      $('.dropdown-funcionario').live('change', function () {
        validateFuncionario(this.value);
      });

    });

  </script>


