<script type="application/javascript">
  window.dataLayer = window.dataLayer;

  function gtag() {
    dataLayer.push(arguments);
  }

  gtag('js', new Date());

  gtag('config', 'UA-115667928-1');

  function abreMenu(a) {
    if (a.classList.contains('ativo')) {
      a.classList.remove('ativo');
    } else {
      var lista = document.getElementById("itensMenu").getElementsByClassName("item-menu");
      for (var i = 0; i < lista.length; i++) {
        lista[i].classList.remove('ativo');
      }
      a.classList.add('ativo');
    }
  }

  function abreMenuPricing(a) {
    var aList = document.querySelectorAll('.item-modulo-menu-pricing.pricing-ativo');
    for (var i = 0; i < aList.length; i++) {
      if (a != aList[i]) {
        aList[i].classList.remove('pricing-ativo');
      }
    }
    if (a.classList.contains('pricing-ativo')) {
      a.classList.remove('pricing-ativo');
    } else {
      a.classList.add('pricing-ativo');
    }
  }

  function abreSubMenuPricing(a) {
    var aList = document.querySelectorAll('.option-menu-pricing-funcionalidade-anchor');
    for (var i = 0; i < aList.length; i++) {
      if (a != aList[i]) {
        aList[i].classList.remove('pricing-ativo');
      }
    }
    if (a.classList.contains('pricing-ativo')) {
      a.classList.remove('pricing-ativo');
    } else {
      a.classList.add('pricing-ativo');
    }
  }

  function setToastrOption() {
    toastr.options = {
      "closeButton": true,
      "debug": false,
      "newestOnTop": false,
      "progressBar": true,
      "positionClass": "toast-top-right",
      "preventDuplicates": true,
      "onclick": null,
      "showDuration": "300",
      "hideDuration": "1000",
      "timeOut": "7500",
      "extendedTimeOut": "1000",
      "showEasing": "swing",
      "hideEasing": "linear",
      "showMethod": "fadeIn",
      "hideMethod": "fadeOut"
    }
  }

  setToastrOption();


  function fallbackCopyTextToClipboard(text) {
    var textArea = document.createElement("textarea");
    textArea.value = text;
    document.body.appendChild(textArea);
    textArea.focus();
    textArea.select();

    try {
      var successful = document.execCommand('copy');
      if (successful) {
        toastr['success']('Copiado!', '');
      }
    } catch (err) {
      console.error('Fallback: Oops, unable to copy', err);
    }

    document.body.removeChild(textArea);
  }

  function copyTextToClipboard(text) {
    if (!navigator.clipboard) {
      fallbackCopyTextToClipboard(text);
      return;
    }
    navigator.clipboard.writeText(text).then(function () {
      toastr['success']('Copiado!', '');
    }, function (err) {
      console.error('Async: Could not copy text: ', err);
    });
  }
</script>


<script>
  $(document).ready(function () {
    if (localStorage.getItem("hideHelp") === 'hide') {
      $(".span-link-hide").hide();
      $(".help-float").css({right: '-100px', opacity: 0.75});
    } else {
      $(".span-link-show").hide();
    }

    $(".span-link-show").click(function () {
      $(".span-link-show").hide();
      $(".span-link-hide").show();
      $(".help-float").animate({right: '40px', opacity: 1});
      localStorage.setItem("hideHelp", 'show');
    });

    $(".span-link-hide").click(function () {
      $(".span-link-hide").hide();
      $(".span-link-show").show();
      $(".help-float").animate({right: '-100px', opacity: 0.75});
      localStorage.setItem("hideHelp", 'hide');
    });
  });

</script>

<script>

  var filterFuncionarioInitRange = 2000;

  function confirmToastAction(body) {
    $.ajax({
      url: '/Tangerino/ws/toastActions/confirm',
      type: "POST",
      contentType: "application/json; charset=utf-8",
      dataType: "json",
      beforeSend: function (xhr) {
        xhr.setRequestHeader('Content-Type', 'application/json; charset=utf-8');
      },
      data: JSON.stringify(body),
      success: function (response) {
        toastr.clear();
        if (typeof responseSuccessToast === "function") {
          responseSuccessToast(response); //implemente esse método na página se necessário.
        } else {
          toastr['success'](response != null ? response : 'Sucesso!', '');
        }
      },
      error: function () {
        toastr.clear();
        toastr['error']('Erro no servidor, tente novamente.', '');
      },
    });
  }

  $('.dropdown-funcionario').select2({
    language: {
      inputTooShort: function (a) {
        return "Favor digitar " + (a.minimum - a.input.length) + " ou mais caracteres"
      }
    },
    minimumInputLength: $('.dropdown-funcionario option').length > filterFuncionarioInitRange ? 3 : 0,
    theme: "bootstrap"
  });
</script>

<script>
  var dataLayer = window.dataLayer;
  window.addEventListener("message", receiveMessage, false);

  function receiveMessage(event) {
    if (event.data.type !== "gtm")
      return;

    dataLayer.push(event.data)
  }
</script>

